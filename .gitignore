# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Secrets / local config
.env
.env.*
!.env.example

# Trained agents (regenerate via `python -m rl.run`). The per-condition run
# directories hold model.zip files; keep the aggregate result tables/JSON.
artifacts/rl/*/model.zip
artifacts/rl/*/training_log.csv
artifacts/rl_smoke/
!artifacts/rl/rl_results_*.csv
!artifacts/rl/rl_metrics_per_seed.json

# DL artifacts (weights + predictions are produced on Colab; not redistributed)
artifacts/dl/*.h5
artifacts/dl/*.weights.h5
artifacts/dl/*.npz

# OS / editor
.DS_Store
.vscode/
.idea/
